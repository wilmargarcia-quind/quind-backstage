# Auth.js v5 — GitHub OAuth App credentials
# Create an OAuth App at: https://github.com/organizations/quind/settings/applications
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# Auth.js secret for JWT encryption — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# GitHub organization name used for team-role mapping
GITHUB_ORG=quind

# Next.js public URL (required in production)
# NEXTAUTH_URL=https://backstage.quind.io
